{
  "name": "pt-emr-simulator",
  "version": "2.0.0",
  "description": "Modernized Physical Therapy EMR Simulator - Pure Frontend Application (2025)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"app/js/**/*.js\"",
    "format": "prettier -w .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.check.json && eslint \"app/js/**/*.js\" && prettier -c .",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/generate-icons.mjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "eslint": "^9.11.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.12.0",
    "husky": "^9.1.4",
    "jsdom": "^29.0.1",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.5.1",
    "sharp": "^0.33.5",
    "svelte": "^5.20.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  },
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danstonedev/VSPx-EMRsim.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/danstonedev/VSPx-EMRsim/issues"
  },
  "homepage": "https://github.com/danstonedev/VSPx-EMRsim#readme",
  "lint-staged": {
    "app/**/*.{js,jsx,css,html,json,md}": "prettier --write",
    "src/**/*.{ts,svelte,css,html,json}": "prettier --write",
    "*.{json,md,yml,yaml}": "prettier --write",
    "!.husky/**": "echo skip"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.0"
  },
  "dependencies": {
    "docx": "^9.6.1"
  }
}
